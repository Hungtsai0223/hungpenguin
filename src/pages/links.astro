---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Links — Ralf Tsai"
  description="Links to Ralf Tsai's social media, writing, and portfolio."
>
  <main class="links-page">
    <!-- 背景圖片：請放在 public/links-bg.jpg -->
    <div class="bg-image" aria-hidden="true"></div>
    <div class="bg-overlay" aria-hidden="true"></div>

    <section class="profile">
      <img class="avatar" src="/profile.jpg" alt="Portrait of Ralf Tsai" />

      <h1>Contact with me</h1>

      <p class="bio">
        Research, writing, sustainability, and small observations from life by the sea.
      </p>
    </section>

    <section class="icon-grid" aria-label="Social and portfolio links">
      <a
        class="icon-link"
        href="https://www.linkedin.com/in/hungtsai0223/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <span class="icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.3 8.1h4.4V23H.3V8.1ZM7.6 8.1h4.2v2.04h.06c.58-1.1 2-2.26 4.12-2.26 4.4 0 5.22 2.9 5.22 6.66V23h-4.4v-7.5c0-1.8-.03-4.1-2.5-4.1-2.5 0-2.88 1.95-2.88 3.96V23H7.6V8.1Z" />
          </svg>
        </span>
        <span class="label">LinkedIn</span>
      </a>

      <a
        class="icon-link"
        href="https://www.instagram.com/ifnoplastic.tw/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
      >
        <span class="icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm4.2 3.8A4.2 4.2 0 1 1 7.8 12 4.2 4.2 0 0 1 12 7.8Zm0 2A2.2 2.2 0 1 0 14.2 12 2.2 2.2 0 0 0 12 9.8Zm4.8-3.1a1 1 0 1 1-1 1 1 1 0 0 1 1-1Z" />
          </svg>
        </span>
        <span class="label">Instagram</span>
      </a>

      <a
        class="icon-link"
        href="https://www.dcard.tw/@ralfwu0330"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Dcard"
      >
        <span class="icon text-icon">D</span>
        <span class="label">Dcard</span>
      </a>

      <a
        class="icon-link"
        href="https://medium.com/@hungtsai"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Medium"
      >
        <span class="icon text-icon">M</span>
        <span class="label">Medium</span>
      </a>

      <a
        class="icon-link"
        href="mailto:ifnoplastic@gmail.com"
        aria-label="Email"
      >
        <span class="icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 5h18v14H3V5Zm2 2v.3l7 5.1 7-5.1V7H5Zm14 2.8-7 5.1-7-5.1V17h14V9.8Z" />
          </svg>
        </span>
        <span class="label">Email</span>
      </a>
    </section>

    <section class="note">
      <p>
        For collaborations, talks, writing, or environmental education projects,
        feel free to reach out through any of the links above.
      </p>
    </section>
  </main>
</Layout>

<style>
  .links-page {
    position: relative;
    isolation: isolate;
    min-height: 68vh;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 38px;
    text-align: center;
    overflow: hidden;
    border-radius: 34px;
    padding: 72px 24px;
  }

  /* 背景圖片 */
  .bg-image {
    position: absolute;
    inset: 0;
    z-index: -3;

    /* 背景圖路徑：圖片請放在 public/links-bg.jpg */
    background-image: url("/links-bg.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

    /* 背景圖清晰度與存在感 */
    opacity: 0.9;
    filter: brightness(0.95) contrast(0.9) saturate(0.75);
    transform: scale(1.03);
  }

  /* 白色霧面遮罩，讓文字和 icon 清楚 */
  .bg-overlay {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;

    /*
      想讓背景更明顯：把 0.78 改成 0.68
      想讓背景更淡：把 0.78 改成 0.86
    */
    background:
      linear-gradient(
        180deg,
        rgba(251, 252, 248, 0.82) 0%,
        rgba(251, 252, 248, 0.76) 50%,
        rgba(251, 252, 248, 0.84) 100%
      ),
      radial-gradient(
        circle at 50% 28%,
        rgba(168, 200, 240, 0.28),
        transparent 42%
      );
  }

  .profile {
    display: grid;
    justify-items: center;
    position: relative;
    z-index: 1;
  }

  .avatar {
    width: 148px;
    height: 148px;
    object-fit: cover;
    object-position: center;
    border-radius: 999px;
    border: 5px solid white;
    box-shadow: 0 22px 52px rgba(26, 39, 68, 0.16);
  }

  h1 {
    margin: 24px 0 10px;
    color: #1a2744;

    /* Contact with me 字體大小在這裡調整 */
    font-size: clamp(40px, 6vw, 58px);

    line-height: 1;
    letter-spacing: -0.055em;
    font-weight: 800;
  }

  .bio {
    max-width: 560px;
    margin: 0;
    color: rgba(26, 39, 68, 0.68);
    font-size: 18px;
    line-height: 1.7;
  }

  .icon-grid {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 28px;
    width: min(100%, 620px);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .icon-link {
    width: 92px;
    display: grid;
    justify-items: center;
    gap: 10px;
    color: rgba(26, 39, 68, 0.66);
    text-decoration: none;
    transition:
      color 0.18s ease,
      transform 0.18s ease;
  }

  .icon-link:hover {
    color: #1a2744;
    transform: translateY(-4px);
  }

  .icon {
    width: 60px;
    height: 60px;
    display: grid;
    place-items: center;
    border-radius: 22px;

    /*
      icon 背景透明度：
      想更淡：0.58 改 0.42
      想更明顯：0.58 改 0.75
    */
    background: rgba(168, 200, 240, 0.58);

    color: currentColor;
    box-shadow: 0 14px 34px rgba(26, 39, 68, 0.08);
    backdrop-filter: blur(6px);
    transition:
      background 0.18s ease,
      box-shadow 0.18s ease;
  }

  .icon-link:hover .icon {
    background: #a8c8f0;
    box-shadow: 0 18px 42px rgba(26, 39, 68, 0.14);
  }

  .icon svg {
    width: 28px;
    height: 28px;
    fill: currentColor;
  }

  .text-icon {
    font-size: 24px;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .label {
    font-size: 14px;
    font-weight: 750;
    color: rgba(26, 39, 68, 0.62);
  }

  .icon-link:hover .label {
    color: #1a2744;
  }

  .note {
    max-width: 560px;
    padding-top: 14px;
    border-top: 1px solid rgba(26, 39, 68, 0.12);
    position: relative;
    z-index: 1;
  }

  .note p {
    margin: 0;
    color: rgba(26, 39, 68, 0.62);
    font-size: 15.5px;
    line-height: 1.7;
  }

  @media screen and (max-width: 720px) {
    .links-page {
      min-height: auto;
      align-content: start;
      gap: 34px;
      padding: 48px 18px;
      border-radius: 28px;
    }

    .avatar {
      width: 128px;
      height: 128px;
    }

    .bio {
      font-size: 16px;
    }

    .icon-grid {
      gap: 22px 10px;
      width: min(100%, 360px);
    }

    .icon-link {
      width: 96px;
    }

    .icon {
      width: 56px;
      height: 56px;
      border-radius: 20px;
    }

    .bg-image {
      opacity: 0.34;
      background-position: center;
    }

    .bg-overlay {
      background: rgba(251, 252, 248, 0.82);
    }
  }
</style>